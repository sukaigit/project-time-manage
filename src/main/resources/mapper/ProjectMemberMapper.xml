<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ptm.mapper.ProjectMemberMapper">

    <resultMap id="BaseResultMap" type="com.ptm.entity.ProjectMember">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="project_id" property="projectId" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
    </resultMap>

    <sql id="BaseColumns">
        id, project_id, user_id
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_project_member (project_id, user_id)
        VALUES (#{projectId}, #{userId})
    </insert>

    <insert id="insertBatch">
        INSERT INTO tb_project_member (project_id, user_id) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.projectId}, #{item.userId})
        </foreach>
    </insert>

    <delete id="deleteById">
        DELETE FROM tb_project_member WHERE id = #{id}
    </delete>

    <delete id="deleteByProjectId">
        DELETE FROM tb_project_member WHERE project_id = #{projectId}
    </delete>

    <delete id="deleteByProjectIdAndUserId">
        DELETE FROM tb_project_member WHERE project_id = #{projectId} AND user_id = #{userId}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM tb_project_member WHERE id = #{id}
    </select>

    <select id="selectByProjectId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM tb_project_member WHERE project_id = #{projectId}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM tb_project_member WHERE user_id = #{userId}
    </select>

    <select id="findMembersByProjectId" resultType="com.ptm.entity.User">
        SELECT u.id, u.username, u.name, u.dept, u.status
        FROM tb_user u
        INNER JOIN tb_project_member pm ON u.id = pm.user_id
        WHERE pm.project_id = #{projectId}
    </select>

    <insert id="insertByParams">
        INSERT INTO tb_project_member (project_id, user_id) VALUES (#{projectId}, #{userId})
    </insert>

</mapper>
