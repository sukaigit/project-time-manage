<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ptm.mapper.UserRoleMapper">

    <resultMap id="BaseResultMap" type="com.ptm.entity.UserRole">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="role_id" property="roleId" jdbcType="BIGINT"/>
    </resultMap>

    <sql id="BaseColumns">
        id, user_id, role_id
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_user_role (user_id, role_id)
        VALUES (#{userId}, #{roleId})
    </insert>

    <delete id="deleteById">
        DELETE FROM tb_user_role WHERE id = #{id}
    </delete>

    <delete id="deleteByUserId">
        DELETE FROM tb_user_role WHERE user_id = #{userId}
    </delete>

    <delete id="deleteByUserIdAndRoleId">
        DELETE FROM tb_user_role WHERE user_id = #{userId} AND role_id = #{roleId}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM tb_user_role WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM tb_user_role WHERE user_id = #{userId}
    </select>

    <select id="selectByRoleId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM tb_user_role WHERE role_id = #{roleId}
    </select>

    <select id="countByRoleId" resultType="long">
        SELECT COUNT(*) FROM tb_user_role WHERE role_id = #{roleId}
    </select>

    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM tb_user_role WHERE user_id = #{userId}
    </select>

    <insert id="insertByParams">
        INSERT INTO tb_user_role (user_id, role_id) VALUES (#{userId}, #{roleId})
    </insert>

</mapper>
